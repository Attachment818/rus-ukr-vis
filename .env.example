# Copy this file to .env and fill in local credentials.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=rus_ukr_analysis

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Chat / reasoning LLM. SiliconFlow is OpenAI-compatible. The visible docs use
# /v1/chat/completions, so the SDK base URL should stop at /v1.
CHAT_OPENAI_API_KEY=your_siliconflow_api_key
CHAT_OPENAI_BASE_URL=https://api.siliconflow.cn/v1
CHAT_OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2

# Embedding model for document chunk vectorization and semantic retrieval.
EMBEDDING_OPENAI_API_KEY=your_siliconflow_api_key
EMBEDDING_OPENAI_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_OPENAI_MODEL=Qwen/Qwen3-Embedding-8B
